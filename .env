# =========================================================================
# SMART CAMPUS CONNECT - DOCKER ENVIRONMENT SETTINGS
# =========================================================================

# Database Configuration
FORWARD_DB_PORT=3306
DB_DATABASE=smartcampus
DB_USERNAME=root
DB_PASSWORD=
DB_ROOT_PASSWORD=

# REST API Backend Configuration (Spring Boot - Port 8080)
FORWARD_API_PORT=8080

# SOAP/WSDL Service Configuration (JAX-WS Legacy Booking - Port 8085)
# Access WSDL at: http://localhost:8085/ws/booking?wsdl
FORWARD_SOAP_PORT=8085

# TCP Notification Socket Server Configuration (Producer-Consumer Messaging - Port 9090)
FORWARD_NOTIFY_PORT=9090

# Web Frontend Configuration (Nginx - Port 3000)
FORWARD_WEB_PORT=3000
