    {
      "name": "🏢 Booking Services SOAP (R8)",
      "item": [
        {
          "name": "bookRoom — Tempah Bilik",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "text/xml", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:ser=\"http://service.smartcampus/\">\n   <soapenv:Header/>\n   <soapenv:Body>\n      <ser:bookRoom>\n         <studentId>B032310001</studentId>\n         <studentName>Muhammad Azim bin Aminudin</studentName>\n         <roomName>DKG4</roomName>\n         <slot>10:00-12:00</slot>\n         <date>2026-06-01</date>\n         <purpose>Kajian Kumpulan Teragih</purpose>\n      </ser:bookRoom>\n   </soapenv:Body>\n</soapenv:Envelope>",
              "options": { "raw": { "language": "xml" } }
            },
            "url": {
              "raw": "http://localhost:8085/ws/booking",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8085",
              "path": ["ws", "booking"]
            },
            "description": "SOAP R8: Tempah bilik kuliah. Returns bookingRef (e.g. BK-20260601-XXX).\nSOAP Fault jika bilik + slot + tarikh sudah ditempah."
          },
          "response": []
        },
        {
          "name": "checkAvailability — Semak Kekosongan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "text/xml", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:ser=\"http://service.smartcampus/\">\n   <soapenv:Header/>\n   <soapenv:Body>\n      <ser:checkAvailability>\n         <roomName>DKG4</roomName>\n         <slot>10:00-12:00</slot>\n         <date>2026-06-01</date>\n      </ser:checkAvailability>\n   </soapenv:Body>\n</soapenv:Envelope>",
              "options": { "raw": { "language": "xml" } }
            },
            "url": {
              "raw": "http://localhost:8085/ws/booking",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8085",
              "path": ["ws", "booking"]
            },
            "description": "Returns true (available) or false (already booked)."
          },
          "response": []
        },
        {
          "name": "cancelBooking — Batalkan Tempahan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "text/xml", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:ser=\"http://service.smartcampus/\">\n   <soapenv:Header/>\n   <soapenv:Body>\n      <ser:cancelBooking>\n         <bookingRef>BK-20260601-001</bookingRef>\n      </ser:cancelBooking>\n   </soapenv:Body>\n</soapenv:Envelope>",
              "options": { "raw": { "language": "xml" } }
            },
            "url": {
              "raw": "http://localhost:8085/ws/booking",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8085",
              "path": ["ws", "booking"]
            },
            "description": "Gantikan bookingRef dengan ref yang diterima dari bookRoom. SOAP Fault jika ref tidak wujud atau sudah dibatalkan."
          },
          "response": []
        },
        {
          "name": "borrowBook — Pinjam Buku",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "text/xml", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:ser=\"http://service.smartcampus/\">\n   <soapenv:Header/>\n   <soapenv:Body>\n      <ser:borrowBook>\n         <studentId>B032310001</studentId>\n         <studentName>Muhammad Azim bin Aminudin</studentName>\n         <isbn>978-3-16-148410-0</isbn>\n         <title>Introduction to Distributed Systems</title>\n      </ser:borrowBook>\n   </soapenv:Body>\n</soapenv:Envelope>",
              "options": { "raw": { "language": "xml" } }
            },
            "url": {
              "raw": "http://localhost:8085/ws/booking",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8085",
              "path": ["ws", "booking"]
            },
            "description": "Returns loanRef (e.g. LN-20260525-XXX). Tempoh pinjaman 14 hari."
          },
          "response": []
        },
        {
          "name": "returnBook — Pulangkan Buku (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "text/xml", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:ser=\"http://service.smartcampus/\">\n   <soapenv:Header/>\n   <soapenv:Body>\n      <ser:returnBook>\n         <loanRef>LN-20260525-001</loanRef>\n      </ser:returnBook>\n   </soapenv:Body>\n</soapenv:Envelope>",
              "options": { "raw": { "language": "xml" } }
            },
            "url": {
              "raw": "http://localhost:8085/ws/booking",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8085",
              "path": ["ws", "booking"]
            },
            "description": "Admin sahkan pemulangan buku. Kira denda jika lambat (RM1/hari). Gantikan loanRef dengan ref dari borrowBook."
          },
          "response": []
        }
      ]
    }
