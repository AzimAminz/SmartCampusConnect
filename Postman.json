  "item": [
    {
      "name": "🔐 Auth API",
      "item": [
        {
          "name": "Login (Student)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"B032310001\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "login"]
            },
            "description": "Login menggunakan no. matrik sahaja (tiada password). Kembalikan token UUID.\nSalin token dan letak dalam header X-Auth-Token untuk request seterusnya."
          },
          "response": []
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"ADMIN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "login"]
            },
            "description": "Login sebagai Admin. userId = ADMIN. Kembalikan token + role ADMIN."
          },
          "response": []
        },
        {
          "name": "Who Am I (me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Auth-Token", "value": "{{auth_token}}", "type": "text" }
            ],
            "url": {
              "raw": "http://localhost:8080/api/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "me"]
            },
            "description": "Semak maklumat pengguna yang sedang login berdasarkan token. Gantikan {{auth_token}} dengan token dari response login."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Auth-Token", "value": "{{auth_token}}", "type": "text" }
            ],
            "url": {
              "raw": "http://localhost:8080/api/auth/logout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "logout"]
            },
            "description": "Hapus sesi login. Token tidak lagi sah selepas ini."
          },
          "response": []
        }
      ]
    },
