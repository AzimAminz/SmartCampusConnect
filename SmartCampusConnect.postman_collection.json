              "mode": "raw",
              "raw": "<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:ser=\"http://service.smartcampus/\">\n   <soapenv:Header/>\n   <soapenv:Body>\n      <ser:bookRoom>\n         <studentId>B032310001</studentId>\n         <studentName>Ahmad Bin Ali</studentName>\n         <roomName>DKG4</roomName>\n         <slot>10:00-12:00</slot>\n         <date>2026-06-01</date>\n         <purpose>Kajian Kumpulan Teragih</purpose>\n      </ser:bookRoom>\n   </soapenv:Body>\n</soapenv:Envelope>\n",
